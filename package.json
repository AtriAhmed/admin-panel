{
  "name": "admin-panel-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:bff": "npm --workspace apps/auth-bff run dev",
    "build:admin": "npm --workspace apps/admin run build",
    "build:bff": "npm --workspace apps/auth-bff run build",
    "typecheck:bff": "npm --workspace apps/auth-bff run typecheck",
    "lint:mobile": "npm --workspace apps/mobile run lint"
  }
}
